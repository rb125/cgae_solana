# Copy this file to `.env` and fill in real values.
# Never commit real secrets.

# ---------------------------------------------------------------------------
# Core LLM credentials (required for `python -m server.live_runner`)
# ---------------------------------------------------------------------------
AZURE_API_KEY=
AZURE_OPENAI_API_ENDPOINT=https://your-azure-openai-resource.openai.azure.com/
FOUNDRY_MODELS_ENDPOINT=https://your-azure-ai-foundry-endpoint.openai.azure.com/v1

# Gemma-4 via Modal (optional)
GEMMA_BASE_URL=
GEMMA_API_KEY=not-needed
GEMMA_MODEL=google/gemma-4-26B-A4B-it

# AWS Bedrock (optional, for nova-pro, claude-sonnet-4.6, MiniMax-M2.5)
AWS_BEARER_TOKEN_BEDROCK=

# ---------------------------------------------------------------------------
# Framework service endpoints
# Run locally: localhost:8001 (CDCT), localhost:8002 (DDFT), localhost:8003 (EECT/AGT)
# ---------------------------------------------------------------------------
CDCT_API_URL=http://localhost:8001
DDFT_API_URL=http://localhost:8002
EECT_API_URL=http://localhost:8003

# ---------------------------------------------------------------------------
# Solana (optional, for on-chain deployment and storage)
# ---------------------------------------------------------------------------
SOLANA_PRIVATE_KEY=
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# IPFS storage via Pinata (optional, enables real audit certificate uploads)
# Free tier: 1 GB, 500 files, no credit card
# Sign up: https://app.pinata.cloud/auth/sign-up
# API key: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# Program ID emitted by `anchor deploy` (auto-set in Anchor.toml)
CGAE_PROGRAM_ID=

# ---------------------------------------------------------------------------
# Dashboard (optional, for Streamlit Cloud -> Modal backend)
# ---------------------------------------------------------------------------
MODAL_ENDPOINT=
